# Google Cloud / BigQuery
GCP_PROJECT=ecommerce-project-496110

# Validation split
# Number of latest snapshot_date values used as validation data.
VAL_LAST_N_SNAPSHOTS=1

# Hurdle model
# Probability threshold for hard hurdle predictions.
NONZERO_THRESHOLD=0.5

# Feature engineering
# Available values:
# - base: raw numeric features + category one-hot encoding
# - funnel: base + funnel/price indicator features
# - extended: funnel + sales/price interaction features
FEATURE_SET=extended

# MLflow
MLFLOW_TRACKING_URI=file:./ml/mlruns
MLFLOW_EXPERIMENT=hurdle_product_demand

# Local artifacts
ARTIFACT_DIR=./ml/artifacts
